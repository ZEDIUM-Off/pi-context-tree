{
	"$schema": "https://raw.githubusercontent.com/ZEDIUM-Off/pi-context-tree/v0.3.0/schemas/context.schema.json",
	"stability": {
		"state": "stable",
		"summary": "Repository-wide extension configuration and docs are usable baseline; prefer narrower child scope stability when present.",
		"updatedAt": "2026-04-28",
		"updatedBy": "agent"
	},
	"defaults": {
		"cache": {
			"mode": "ttl",
			"ttl": "14d",
			"fallback": "stale"
		},
		"budget": {
			"maxTokens": 3000,
			"perSourceMaxTokens": 2000
		}
	},
	"sources": {
		"schema": {
			"type": "file",
			"path": "./src/context-schema.ts",
			"kind": "schema",
			"reason": "Canonical CONTEXT.json Zod schema",
			"mode": {
				"type": "ref"
			}
		},
		"readme": {
			"type": "file",
			"path": "./README.md",
			"kind": "overview",
			"reason": "Project overview; load only when task needs broad orientation",
			"mode": {
				"type": "inline"
			}
		},
		"package": {
			"type": "file",
			"path": "./package.json",
			"kind": "package-metadata",
			"reason": "TypeScript package metadata: scripts, dependencies, Pi extension entrypoint",
			"mode": {
				"type": "inline"
			}
		}
	},
	"injection_rules": [
		{
			"inject": [
				{
					"source": "readme",
					"on": "session:start"
				},
				{
					"source": "package",
					"on": "session:start"
				},
				{
					"source": "schema",
					"on": "agent:start"
				}
			]
		},
		{
			"match": [
				"CONTEXT.json",
				"**/CONTEXT.json"
			],
			"inject": [
				{
					"source": "schema",
					"on": "tool:read"
				},
				{
					"source": "schema",
					"on": [
						"tool:edit",
						"tool:write"
					],
					"mode": {
						"type": "inline"
					}
				}
			]
		}
	]
}
