{
	"$schema": "../schemas/context.schema.json",
	"stability": {
		"state": "stable",
		"summary": "Maintenance scripts are stable support code. Keep aligned with canonical schema implementation in src/context-schema.ts.",
		"updatedAt": "2026-04-28",
		"updatedBy": "agent"
	},
	"hooks": [
		{
			"on": "agent:start",
			"inject": [
				"../src/context-schema.ts"
			]
		},
		{
			"on": "tool:read",
			"match": [
				"**/*.ts"
			],
			"inject": [
				"../src/context-schema.ts"
			]
		},
		{
			"on": "tool:edit",
			"match": [
				"**/*.ts"
			],
			"inject": [
				{
					"type": "file",
					"path": "../src/context-schema.ts",
					"kind": "schema",
					"reason": "JSON Schema generator derives from canonical Zod schema",
					"mode": {
						"type": "inline"
					}
				}
			]
		},
		{
			"on": "tool:write",
			"match": [
				"**/*.ts"
			],
			"inject": [
				{
					"type": "file",
					"path": "../src/context-schema.ts",
					"kind": "schema",
					"reason": "JSON Schema generator derives from canonical Zod schema",
					"mode": {
						"type": "inline"
					}
				}
			]
		}
	]
}
