{
	"$schema": "https://raw.githubusercontent.com/ZEDIUM-Off/pi-context-tree/v0.4.0/schemas/context.schema.json",
	"stability": {
		"state": "stable",
		"summary": "Maintenance scripts are stable support code. Keep aligned with canonical schema implementation in src/context-schema.ts.",
		"updatedAt": "2026-04-28",
		"updatedBy": "agent"
	},
	"sources": {
		"schema": {
			"type": "file",
			"path": "../src/context-schema.ts",
			"kind": "schema",
			"reason": "JSON Schema generator derives from canonical Zod schema",
			"mode": {
				"type": "ref"
			}
		},
		"releaseChecklist": {
			"type": "file",
			"path": "../docs/release-checklist.md",
			"kind": "release-rules",
			"reason": "Packaging, local dev, and schema release scripts must follow release expectations",
			"mode": {
				"type": "ref"
			}
		}
	},
	"injection_rules": [
		{
			"match": [
				"**/*.ts"
			],
			"inject": [
				{
					"source": "schema",
					"on": "tool:read"
				},
				{
					"source": "releaseChecklist",
					"on": "tool:read"
				},
				{
					"source": "schema",
					"on": [
						"tool:edit",
						"tool:write"
					],
					"mode": {
						"type": "inline"
					}
				}
			]
		}
	]
}
