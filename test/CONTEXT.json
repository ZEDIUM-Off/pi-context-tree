{
	"$schema": "https://raw.githubusercontent.com/ZEDIUM-Off/pi-context-tree/v0.3.0/schemas/context.schema.json",
	"stability": {
		"state": "canonical",
		"summary": "Tests define expected behavior for schema, resolver, permissions, and TUI. Use as source of truth for behavior changes.",
		"updatedAt": "2026-04-28",
		"updatedBy": "agent"
	},
	"sources": {
		"implementationTests": {
			"type": "file",
			"path": "../docs/implementation.md",
			"kind": "reference",
			"mode": {
				"type": "sections",
				"names": [
					"Tests unitaires et déterminisme"
				]
			}
		}
	},
	"injection_rules": [
		{
			"inject": [
				{
					"source": "implementationTests",
					"on": "agent:start"
				}
			]
		},
		{
			"match": [
				"**/*.test.ts"
			],
			"inject": [
				{
					"source": "implementationTests",
					"on": "tool:*"
				}
			]
		}
	]
}
