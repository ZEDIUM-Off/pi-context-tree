{
	"name": "pi-context-tree",
	"version": "0.2.0",
	"description": "Pi extension for deterministic path-scoped contextualization via CONTEXT.json files.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ZEDIUM-Off/pi-context-tree.git"
	},
	"bugs": {
		"url": "https://github.com/ZEDIUM-Off/pi-context-tree/issues"
	},
	"homepage": "https://github.com/ZEDIUM-Off/pi-context-tree#readme",
	"scripts": {
		"test": "node --import tsx --test test/**/*.test.ts",
		"typecheck": "tsc --noEmit",
		"validate": "pnpm typecheck && pnpm schema:generate && pnpm test",
		"pi:dev": "pi -e .",
		"pi:check": "pnpm typecheck && pi -e .",
		"pi:install:local": "pi install -l .",
		"pi:local": "pi",
		"schema:generate": "tsx scripts/generate-schema.ts"
	},
	"keywords": [
		"pi-package",
		"pi",
		"pi-extension",
		"coding-agent",
		"context",
		"context-engineering",
		"routing"
	],
	"license": "MIT",
	"packageManager": "pnpm@10.33.2",
	"type": "module",
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"dependencies": {
		"@mariozechner/pi-ai": "^0.70.2",
		"@mariozechner/pi-coding-agent": "^0.70.2",
		"@mariozechner/pi-tui": "^0.70.2",
		"minimatch": "^10.2.5",
		"typebox": "^1.1.33",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@types/node": "latest",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "^0.70.2",
		"@mariozechner/pi-coding-agent": "^0.70.2",
		"@mariozechner/pi-tui": "^0.70.2",
		"typebox": "^1.1.33"
	}
}
