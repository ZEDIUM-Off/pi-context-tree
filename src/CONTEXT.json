{
	"$schema": "../schemas/context.schema.json",
	"version": 1,
	"context": [
		{
			"match": ["index.ts"],
			"operations": ["agent_start", "read", "edit", "write", "session_spawn"],
			"inject": [
				{
					"type": "url",
					"url": "https://raw.githubusercontent.com/badlogic/pi-mono/main/packages/coding-agent/docs/extensions.md",
					"kind": "pi-doc",
					"required": false,
					"reason": "Pi extension lifecycle hooks, system prompt injection, tool interception, messages, commands, UI APIs",
					"extract": {
						"sections": [
							"Lifecycle Overview",
							"Agent Events",
							"Tool Events",
							"ExtensionContext",
							"ExtensionAPI Methods",
							"Custom UI"
						]
					}
				}
			]
		},
		{
			"match": ["context-schema.ts", "context-tree.ts", "permissions.ts"],
			"operations": ["agent_start", "read", "edit", "write", "session_spawn"],
			"inject": [
				{
					"type": "file",
					"path": "../docs/implementation.md",
					"kind": "reference",
					"required": false,
					"extract": {
						"sections": [
							"Schéma cible v1",
							"Résolution des scopes",
							"Résolution `context[]`",
							"Extraction fine",
							"Tests unitaires et déterminisme"
						]
					}
				},
				{
					"type": "url",
					"url": "https://raw.githubusercontent.com/badlogic/pi-mono/main/packages/coding-agent/docs/extensions.md",
					"kind": "pi-doc",
					"required": false,
					"reason": "Pi extension hooks used by core integration"
				}
			]
		}
	]
}
