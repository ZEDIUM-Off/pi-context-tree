{
	"$schema": "https://raw.githubusercontent.com/ZEDIUM-Off/pi-context-tree/v0.3.0/schemas/context.schema.json",
	"stability": {
		"state": "canonical",
		"summary": "Core Context Tree implementation. Treat code here as trusted local pattern for resolver, schema, rules, commands, and TUI behavior.",
		"updatedAt": "2026-04-28",
		"updatedBy": "agent"
	},
	"sources": {
		"piExtensions": {
			"type": "url",
			"url": "https://raw.githubusercontent.com/badlogic/pi-mono/main/packages/coding-agent/docs/extensions.md",
			"kind": "pi-doc",
			"reason": "Pi extension lifecycle hooks, system prompt injection, tool interception, messages, commands, UI APIs",
			"mode": {
				"type": "sections",
				"names": [
					"Lifecycle Overview",
					"Agent Events",
					"Tool Events",
					"ExtensionContext",
					"ExtensionAPI Methods",
					"Custom UI"
				]
			}
		},
		"implementation": {
			"type": "file",
			"path": "../docs/implementation.md",
			"kind": "reference",
			"mode": {
				"type": "ref"
			}
		}
	},
	"injection_rules": [
		{
			"inject": [
				{
					"source": "piExtensions",
					"on": "agent:start"
				},
				{
					"source": "implementation",
					"on": "agent:start"
				}
			]
		},
		{
			"match": [
				"index.ts"
			],
			"inject": [
				{
					"source": "piExtensions",
					"on": "tool:*"
				}
			]
		},
		{
			"match": [
				"context-schema.ts",
				"context-tree.ts",
				"permissions.ts",
				"schema.ts",
				"bundle.ts",
				"normalize.ts",
				"match.ts"
			],
			"inject": [
				{
					"source": "implementation",
					"on": "tool:read"
				},
				{
					"source": "implementation",
					"on": [
						"tool:edit",
						"tool:write"
					],
					"mode": {
						"type": "sections",
						"names": [
							"Schema target",
							"Resolution of scopes",
							"Rule resolution",
							"Runtime behavior",
							"Tests unitaires et déterminisme"
						]
					}
				}
			]
		}
	]
}
