{
	"$schema": "https://raw.githubusercontent.com/ZEDIUM-Off/pi-context-tree/v0.4.0/schemas/context.schema.json",
	"stability": {
		"state": "canonical",
		"summary": "Core Context Tree implementation. Treat code here as trusted local pattern for resolver, schema, rules, commands, and TUI behavior.",
		"updatedAt": "2026-04-28",
		"updatedBy": "agent"
	},
	"sources": {
		"piExtensions": {
			"type": "url",
			"url": "https://raw.githubusercontent.com/badlogic/pi-mono/main/packages/coding-agent/docs/extensions.md",
			"kind": "pi-doc",
			"reason": "Pi extension lifecycle hooks and extension API contracts",
			"mode": {
				"type": "sections",
				"names": [
					"Lifecycle Overview",
					"Agent Events",
					"Tool Events",
					"ExtensionContext",
					"ExtensionAPI Methods"
				]
			}
		},
		"implementation": {
			"type": "file",
			"path": "../docs/implementation.md",
			"kind": "reference",
			"mode": {
				"type": "ref"
			}
		},
		"architecture": {
			"type": "file",
			"path": "../docs/architecture-review.md",
			"kind": "architecture",
			"reason": "Current source responsibility boundaries and target architecture",
			"mode": {
				"type": "sections",
				"names": [
					"Current state",
					"Target architecture",
					"Public API boundaries"
				]
			}
		}
	},
	"injection_rules": [
		{
			"match": [
				"index.ts"
			],
			"inject": [
				{
					"source": "piExtensions",
					"on": "tool:*"
				}
			]
		},
		{
			"match": [
				"context-schema.ts",
				"context-tree.ts",
				"permissions.ts",
				"schema.ts",
				"normalize.ts",
				"match.ts",
				"scan.ts",
				"extract.ts",
				"cache.ts",
				"public-api.ts",
				"hooks.ts"
			],
			"inject": [
				{
					"source": "implementation",
					"on": "tool:read"
				},
				{
					"source": "architecture",
					"on": "tool:read"
				},
				{
					"source": "implementation",
					"on": [
						"tool:edit",
						"tool:write"
					],
					"mode": {
						"type": "sections",
						"names": [
							"Schema target",
							"Resolution of scopes",
							"Matching",
							"Rule resolution",
							"Tests unitaires et déterminisme"
						]
					}
				}
			]
		}
	]
}
